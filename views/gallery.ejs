<script>
  // Functional filter bar — filters vehicle cards by category
  (function () {
    var buttons = document.querySelectorAll('.filter-btn');
    var cards = document.querySelectorAll('.gallery-item');

    buttons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        buttons.forEach(function (b) { b.classList.remove('active'); });
        btn.classList.add('active');

        var filter = btn.getAttribute('data-filter');
        cards.forEach(function (card) {
          var match = filter === 'all' || card.getAttribute('data-category') === filter;
          card.classList.toggle('is-hidden', !match);
        });
      });
    });
  })();

  // Click tracking for WhatsApp / call buttons
  document.addEventListener('click', function (e) {
    var link = e.target.closest('a.book-btn, a.inquire-btn');
    if (!link) return;
    console.log('Booking action:', link.href);
  });
</script>

