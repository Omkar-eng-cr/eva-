<%- include('partials/header') %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:wght@500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap');

  :root{
    --ink:#1F2A24;
    --ink-soft:#5B6660;
    --cream:#F6F3EC;
    --white:#FFFFFF;
    --line:#ECE7DC;
    --green:#2F6F52;
    --green-deep:#1E4A37;
    --green-tint:#E7EFE9;
    --gold:#F2A93B;
    --gold-soft:#FCE7C2;
    --radius-lg:20px;
    --radius-md:14px;
    --shadow: 0 4px 14px rgba(31,42,36,0.08);
    --shadow-hover: 0 18px 34px rgba(31,42,36,0.16);
  }

  * { box-sizing: border-box; }

  /* ---------- HERO ---------- */
  .gallery-hero{ padding: 72px 0 8px; }
  .gallery-hero .eyebrow{
    display:inline-block;
    font-size:12.5px;
    font-weight:700;
    letter-spacing:.09em;
    text-transform:uppercase;
    color:var(--green-deep);
    margin-bottom:14px;
  }
  .gallery-hero h1{
    font-family:'Fraunces',serif;
    font-weight:600;
    font-size:clamp(34px, 5vw, 50px);
    line-height:1.08;
    margin:0 0 14px;
    color:var(--ink);
  }
  .gallery-hero .lede{
    font-size:16.5px;
    color:var(--ink-soft);
    max-width:52ch;
    line-height:1.6;
    margin:0;
  }

  /* ---------- FILTER BAR ---------- */
  .fleet-filter{
    display:flex;
    flex-wrap:wrap;
    gap:10px;
    margin:32px 0 8px;
  }
  .filter-btn{
    appearance:none;
    border:1.5px solid var(--line);
    background:var(--white);
    color:var(--ink-soft);
    font-family:'Manrope',sans-serif;
    font-weight:700;
    font-size:13.5px;
    padding:10px 20px;
    border-radius:999px;
    cursor:pointer;
    transition:background .18s ease, color .18s ease, border-color .18s ease, transform .15s ease;
  }
  .filter-btn:hover{ transform:translateY(-1px); border-color:var(--green); color:var(--green-deep); }
  .filter-btn.active{
    background:var(--ink);
    border-color:var(--ink);
    color:var(--white);
  }

  /* ---------- GALLERY GRID ---------- */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
    gap: 28px;
    padding: 1.5em 0 2em;
  }

  .gallery-item {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.25s ease, box-shadow 0.25s ease, opacity .25s ease;
    position: relative;
    display:flex;
    flex-direction:column;
  }

  .gallery-item:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-hover);
  }

  .gallery-item.is-hidden{
    display:none;
  }

  .gallery-media{
    position:relative;
    overflow:hidden;
  }

  .gallery-item img {
    width: 100%;
    height: 240px;
    object-fit: cover;
    display: block;
    transition: transform .4s ease;
  }
  .gallery-item:hover img{ transform: scale(1.06); }

  .gallery-tag{
    position:absolute;
    top:14px;
    left:14px;
    background:rgba(31,42,36,0.72);
    color:var(--white);
    font-size:11px;
    font-weight:700;
    letter-spacing:.05em;
    text-transform:uppercase;
    padding:5px 11px;
    border-radius:999px;
    backdrop-filter: blur(2px);
  }

  .gallery-caption {
    padding: 1.2em 1.3em 1.4em;
    text-align: left;
    background: var(--white);
    display:flex;
    flex-direction:column;
    gap:12px;
    flex:1;
  }

  .gallery-caption-top{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
  }

  .gallery-caption h3 {
    margin: 0;
    font-family:'Fraunces',serif;
    font-weight:600;
    font-size: 1.2rem;
    color: var(--ink);
    letter-spacing: 0.2px;
  }

  .gallery-caption .price {
    display: inline-block;
    margin: 0;
    padding: 6px 14px;
    background: var(--gold-soft);
    color: #7a4e0a;
    font-weight: 800;
    font-size: 0.85rem;
    border-radius: 999px;
    white-space:nowrap;
  }

  .gallery-caption .seats{
    font-size:13px;
    color:var(--ink-soft);
    margin:0;
  }

  .book-btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:7px;
    margin-top:4px;
    background:#25D366;
    color:var(--white);
    font-weight:700;
    font-size:13.5px;
    text-decoration:none;
    padding:11px 16px;
    border-radius:12px;
    transition: background .18s ease, transform .15s ease;
  }
  .book-btn:hover{ background:#1DA851; transform:translateY(-1px); }
  .book-btn svg{ width:16px; height:16px; flex-shrink:0; }

  /* ---------- INQUIRE / CTA ---------- */
  .inquire-section {
    background: var(--ink);
    color: var(--cream);
    text-align: center;
    padding: 3.6em 1.5em;
    border-radius: var(--radius-lg);
    margin: 3em 0 2em;
    position:relative;
    overflow:hidden;
  }

  .inquire-section::before{
    content:"";
    position:absolute;
    top:0; left:0; right:0;
    height:4px;
    background:linear-gradient(90deg, var(--green) 0%, var(--green) 60%, var(--gold) 100%);
  }

  .inquire-section h2 {
    margin: 0 0 10px;
    font-family:'Fraunces',serif;
    font-weight:600;
    font-size: 1.9rem;
    color: var(--cream);
  }

  .inquire-section p {
    margin: 0 0 26px;
    color: #C9C4B6;
    font-size: 1rem;
  }

  .inquire-actions{
    display:flex;
    gap:14px;
    justify-content:center;
    flex-wrap:wrap;
  }

  .inquire-btn {
    display: inline-flex;
    align-items:center;
    gap:8px;
    background: #25D366;
    color: var(--white);
    font-weight: 800;
    font-size: 1.02rem;
    padding: 14px 30px;
    border-radius: 999px;
    text-decoration: none;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .inquire-btn:hover {
    background: #1DA851;
    transform: scale(1.05);
  }

  .inquire-btn.secondary{
    background:transparent;
    color:var(--cream);
    border:1.5px solid rgba(241,238,230,0.35);
  }
  .inquire-btn.secondary:hover{
    background:rgba(241,238,230,0.08);
    border-color:var(--cream);
    transform:scale(1.03);
  }

  @media (max-width: 600px){
    .gallery-hero{ padding-top: 48px; }
    .inquire-section{ padding: 2.6em 1.2em; }
  }

  @media (prefers-reduced-motion: reduce){
    .gallery-item, .gallery-item img, .book-btn, .filter-btn, .inquire-btn{ transition:none; }
  }
</style>

