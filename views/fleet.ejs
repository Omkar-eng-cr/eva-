<%- include('partials/header') %>

<section class="hero" style="padding-bottom: 2em;">
  <div class="container" style="grid-template-columns: 1fr;">
    <div class="hero-copy">
      <span class="eyebrow">Our Fleet</span>
      <h1>A cab for<br>every route.</h1>
      <p class="lede">
        From a quick city hop to a full family trip, Eva Tours and Travels
        keeps four vehicle classes on the road — all AC, all cleaned between
        rides.
      </p>
      <div class="hero-actions">
        <a href="tel:+91<%= business.phone1 %>" class="btn btn-primary">Call &amp; Book a Cab</a>
        <a href="/packages" class="btn btn-ghost">See Package Rates</a>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="container">
    <div class="grid grid-4">

      <div class="card">
        <svg class="icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="6" y="18" width="36" height="14" rx="3" stroke="#2f6f52" stroke-width="2.5"/><path d="M10 18l3-8h22l3 8" stroke="#2f6f52" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="15" cy="34" r="3" fill="#f2a93b"/><circle cx="33" cy="34" r="3" fill="#f2a93b"/></svg>
        <span class="card-tag">4 Seats</span>
        <h3>Hatchback</h3>
        <p>Best for local city rides and short hops. Easy to park, easy on the fare.</p>
      </div>

      <div class="card">
        <svg class="icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="5" y="20" width="38" height="13" rx="3" stroke="#2f6f52" stroke-width="2.5"/><path d="M9 20l4-9h22l4 9" stroke="#2f6f52" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/><rect x="16" y="12" width="16" height="8" rx="1.5" fill="#3a4340"/><circle cx="14" cy="35" r="3" fill="#f2a93b"/><circle cx="34" cy="35" r="3" fill="#f2a93b"/></svg>
        <span class="card-tag">4 Seats</span>
        <h3>Sedan</h3>
        <p>The default pick for airport transfers and city-to-city trips. Extra boot space.</p>
      </div>

      <div class="card">
        <svg class="icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="16" width="40" height="17" rx="3" stroke="#2f6f52" stroke-width="2.5"/><path d="M8 16l4-10h24l4 10" stroke="#2f6f52" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="14" cy="36" r="3.5" fill="#f2a93b"/><circle cx="34" cy="36" r="3.5" fill="#f2a93b"/></svg>
        <span class="card-tag">6-7 Seats</span>
        <h3>SUV</h3>
        <p>Built for family trips and hill routes — more room, more ground clearance.</p>
      </div>

      <div class="card">
        <svg class="icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="14" width="40" height="20" rx="3" stroke="#2f6f52" stroke-width="2.5"/><path d="M4 22h40" stroke="#2f6f52" stroke-width="2"/><circle cx="13" cy="37" r="3.5" fill="#f2a93b"/><circle cx="25" cy="37" r="3.5" fill="#f2a93b"/><circle cx="37" cy="37" r="3.5" fill="#f2a93b"/></svg>
        <span class="card-tag">9-12 Seats</span>
        <h3>Tempo Traveller</h3>
        <p>For group outings and corporate transport, with room for bulk luggage.</p>
      </div>

    </div>
  </div>
</section>

<section class="section-alt">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Compare</span>
      <h2>Which cab fits your trip</h2>
    </div>
    <div class="table-wrap">
      <table class="fleet">
        <thead>
          <tr>
            <th>Vehicle Type</th>
            <th>Best For</th>
            <th>Seats</th>
            <th>Luggage</th>
            <th>AC</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Hatchback</td>
            <td>Local rides, short hops</td>
            <td>4</td>
            <td>2 bags</td>
            <td>Yes</td>
          </tr>
          <tr>
            <td>Sedan</td>
            <td>Airport transfers, city-to-city</td>
            <td>4</td>
            <td>3 bags</td>
            <td>Yes</td>
          </tr>
          <tr>
            <td>SUV</td>
            <td>Family trips, hill routes</td>
            <td>6-7</td>
            <td>4-5 bags</td>
            <td>Yes</td>
          </tr>
          <tr>
            <td>Tempo Traveller</td>
            <td>Group and corporate travel</td>
            <td>9-12</td>
            <td>Bulk luggage</td>
            <td>Yes</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="section-ink">
  <div class="container" style="text-align:center;">
    <h2>Not sure which vehicle to book?</h2>
    <p>Tell us the trip and passenger count — we'll suggest the right cab.</p>
    <a href="tel:+91<%= business.phone1 %>" class="btn btn-primary"><%= business.phone1 %></a>
  </div>
</section>

<%- include('partials/footer') %>