<%- include('partials/header') %>


<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Eva Tours and Travels — Taxi Service in Pune</title>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:wght@500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap');

  :root{
    --ink:#1F2A24;
    --ink-soft:#5B6660;
    --cream:#F6F3EC;
    --white:#FFFFFF;
    --line:#ECE7DC;
    --green:#2F6F52;
    --green-deep:#1E4A37;
    --green-tint:#E7EFE9;
    --gold:#F2A93B;
    --gold-soft:#FCE7C2;
    --radius-lg:20px;
    --radius-md:14px;
    --shadow: 0 1px 2px rgba(31,42,36,0.04), 0 12px 32px -12px rgba(31,42,36,0.18);
  }

  *{box-sizing:border-box;}
  body{
    margin:0;
    background:var(--cream);
    color:var(--ink);
    font-family:'Manrope',sans-serif;
    -webkit-font-smoothing:antialiased;
  }
  h1,h2,h3{font-family:'Fraunces',serif; font-weight:600; margin:0 0 .4em; color:var(--ink);}
  p{margin:0 0 1em; color:var(--ink-soft); line-height:1.6;}
  a{color:inherit;}

  .container{max-width:1120px; margin:0 auto; padding:0 24px;}
  section{padding:88px 0;}
  .section-alt{background:var(--white);}
  .section-head{max-width:560px; margin:0 auto 48px; text-align:center;}
  .section-head p{margin:0;}

  .eyebrow{
    display:inline-block;
    font-size:12.5px;
    font-weight:700;
    letter-spacing:.09em;
    text-transform:uppercase;
    color:var(--green-deep);
    margin-bottom:14px;
  }

  /* ---------- HERO ---------- */
  .hero{padding:96px 0 80px;}
  .hero .container{
    display:grid;
    grid-template-columns:1.1fr 0.9fr;
    gap:56px;
    align-items:center;
  }
  .hero h1{font-size:clamp(38px, 5vw, 58px); line-height:1.05; letter-spacing:-.01em;}
  .accent{color:var(--green);}
  .lede{font-size:17px; max-width:46ch;}
  .hero-actions{display:flex; gap:14px; flex-wrap:wrap; margin-top:8px;}

  .btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:8px;
    padding:14px 24px;
    border-radius:12px;
    font-weight:700;
    font-size:14.5px;
    text-decoration:none;
    transition:transform .15s ease, background .15s ease, border-color .15s ease;
  }
  .btn-primary{background:var(--ink); color:var(--white);}
  .btn-primary:hover{background:var(--green-deep); transform:translateY(-1px);}
  .btn-ghost{background:transparent; color:var(--ink); border:1.5px solid var(--line);}
  .btn-ghost:hover{border-color:var(--green); color:var(--green-deep);}

  /* ---------- BOOKING CARD ---------- */
  .booking-card{
    position:relative;
    width:100%;
    max-width:420px;
    background:var(--white);
    border-radius:var(--radius-lg);
    box-shadow:var(--shadow);
    padding:32px 32px 26px;
    overflow:hidden;
    opacity:0; transform:translateY(14px);
    animation:card-in .6s ease .15s forwards;
  }
  @keyframes card-in{to{opacity:1; transform:translateY(0);}}

  .booking-card::before{
    content:"";
    position:absolute;
    top:0; left:0; right:0;
    height:5px;
    background:linear-gradient(90deg, var(--green) 0%, var(--green) 60%, var(--gold) 100%);
  }

  .booking-card__top{
    display:flex;
    align-items:center;
    justify-content:space-between;
    margin-bottom:20px;
  }
  .booking-card__label{
    display:flex;
    align-items:center;
    gap:8px;
    font-size:12.5px;
    font-weight:700;
    letter-spacing:.09em;
    text-transform:uppercase;
    color:var(--green-deep);
  }
  .booking-card__label svg{width:15px;height:15px;flex-shrink:0;}

  .status-pill{
    display:inline-flex;
    align-items:center;
    gap:6px;
    background:var(--green-tint);
    color:var(--green-deep);
    font-size:12px;
    font-weight:700;
    padding:6px 12px 6px 10px;
    border-radius:999px;
    white-space:nowrap;
  }
  .status-pill .dot{
    width:7px;height:7px;border-radius:50%;
    background:var(--gold);
    animation:booking-pulse 2.2s ease-out infinite;
  }
  @keyframes booking-pulse{
    0%{box-shadow:0 0 0 0 rgba(242,169,59,.5);}
    70%{box-shadow:0 0 0 7px rgba(242,169,59,0);}
    100%{box-shadow:0 0 0 0 rgba(242,169,59,0);}
  }

  .booking-card__number{
    font-family:'Fraunces',serif;
    font-weight:600;
    font-size:clamp(28px, 6vw, 36px);
    line-height:1.1;
    letter-spacing:-.01em;
    color:var(--ink);
    text-decoration:none;
    display:block;
    margin-bottom:4px;
  }
  .booking-card__hint{font-size:14px; margin:0 0 22px;}

  .booking-card__footer{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:12px;
    flex-wrap:wrap;
    padding-top:18px;
    border-top:1px solid var(--line);
  }
  .owner-row{display:flex; align-items:center; gap:10px;}
  .owner-avatar{
    width:34px;height:34px;border-radius:50%;
    background:var(--green);
    color:var(--white);
    font-family:'Fraunces',serif;
    font-weight:600;
    font-size:14px;
    display:flex;align-items:center;justify-content:center;
    flex-shrink:0;
  }
  .owner-meta{display:flex; flex-direction:column; line-height:1.25;}
  .owner-meta strong{font-size:13.5px; font-weight:700; color:var(--ink);}
  .owner-meta span{font-size:12px; color:var(--ink-soft);}

  .booking-card__cta{
    display:inline-flex;
    align-items:center;
    gap:6px;
    background:var(--ink);
    color:var(--white);
    font-size:13px;
    font-weight:700;
    text-decoration:none;
    padding:10px 16px;
    border-radius:12px;
    transition:transform .15s ease, background .15s ease;
  }
  .booking-card__cta:hover{background:var(--green-deep); transform:translateY(-1px);}
  .booking-card__cta svg{width:14px;height:14px;}

  .booking-card.centered{text-align:center; max-width:600px; margin:0 auto;}
  .booking-card.centered .booking-card__top{justify-content:center; position:relative;}
  .booking-card.centered .status-pill{position:absolute; right:0; top:0;}
  .booking-card.centered .booking-card__hint{margin-bottom:26px;}
  .booking-card.centered h2{font-size:26px;}

  .dual-numbers{display:flex; gap:14px; justify-content:center; flex-wrap:wrap; margin-bottom:6px;}
  .dual-numbers a{
    flex:1 1 200px;
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:4px;
    background:var(--cream);
    border:1px solid var(--line);
    border-radius:var(--radius-md);
    padding:16px 18px;
    text-decoration:none;
    color:var(--ink);
    transition:border-color .15s ease, background .15s ease;
  }
  .dual-numbers a:hover{border-color:var(--green); background:var(--green-tint);}
  .dual-numbers small{font-size:11px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--ink-soft);}
  .dual-numbers strong{font-family:'Fraunces',serif; font-size:20px; font-weight:600;}

  /* ---------- SERVICE CARDS ---------- */
  .grid{display:grid; gap:22px;}
  .grid-4{grid-template-columns:repeat(4,1fr);}
  .grid-3{grid-template-columns:repeat(3,1fr);}

  .card{
    background:var(--white);
    border:1px solid var(--line);
    border-radius:var(--radius-md);
    padding:26px 22px;
    opacity:0; transform:translateY(16px);
    transition:transform .25s ease, box-shadow .25s ease;
  }
  .card.in-view{opacity:1; transform:translateY(0); transition:opacity .5s ease, transform .5s ease;}
  .card:hover{transform:translateY(-4px); box-shadow:var(--shadow);}
  .card .icon{margin-bottom:14px;}
  .card h3{font-size:17px; margin-bottom:6px;}
  .card p{font-size:14.5px; margin:0;}

  /* ---------- ROUTE / STEPS ---------- */
  .route{position:relative; max-width:760px; margin:0 auto;}
  .route-track{
    position:absolute; left:50%; top:0; bottom:0; width:2px;
    background:var(--line); transform:translateX(-50%);
  }
  .route-stops{list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:36px;}
  .route-stop{
    display:grid;
    grid-template-columns:1fr auto 1fr;
    align-items:center;
    gap:24px;
    opacity:0; transform:translateY(16px);
  }
  .route-stop.in-view{opacity:1; transform:translateY(0); transition:opacity .5s ease, transform .5s ease;}
  .route-stop .pin{
    width:36px; height:36px; border-radius:50%;
    background:var(--green); color:var(--white);
    display:flex; align-items:center; justify-content:center;
    font-family:'Fraunces',serif; font-weight:600; font-size:14px;
    box-shadow:0 0 0 6px var(--cream);
    z-index:1;
  }
  .route-stop .stop-content{
    background:var(--white);
    border:1px solid var(--line);
    border-radius:var(--radius-md);
    padding:18px 20px;
  }
  .route-stop:nth-child(even) .stop-content{text-align:right;}
  .route-stop h3{font-size:16px; margin-bottom:4px;}
  .route-stop p{font-size:14px; margin:0;}

  /* ---------- STATS ---------- */
  .section-ink{background:var(--ink); padding:64px 0;}
  .stats{display:grid; grid-template-columns:repeat(4,1fr); gap:24px; text-align:center;}
  .stat strong{display:block; font-family:'Fraunces',serif; font-size:32px; font-weight:600; color:var(--gold);}
  .stat span{display:block; font-size:13px; letter-spacing:.05em; text-transform:uppercase; color:#C9D3CC; margin-top:6px;}

  /* ---------- TESTIMONIALS ---------- */
  .testimonial{
    background:var(--white);
    border:1px solid var(--line);
    border-radius:var(--radius-md);
    padding:24px 22px;
    font-size:14.5px;
    line-height:1.65;
    color:var(--ink-soft);
    opacity:0; transform:translateY(16px);
  }
  .testimonial.in-view{opacity:1; transform:translateY(0); transition:opacity .5s ease, transform .5s ease;}

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 860px){
    .hero .container{grid-template-columns:1fr; gap:40px;}
    .grid-4{grid-template-columns:repeat(2,1fr);}
    .grid-3{grid-template-columns:1fr;}
    .route-track{left:18px;}
    .route-stop{grid-template-columns:auto 1fr; gap:14px;}
    .route-stop .spacer{display:none;}
    .route-stop:nth-child(even) .stop-content{text-align:left;}
    .stats{grid-template-columns:repeat(2,1fr); row-gap:32px;}
  }
  @media (max-width: 520px){
    section{padding:64px 0;}
    .grid-4{grid-template-columns:1fr;}
  }

  @media (prefers-reduced-motion: reduce){
    .status-pill .dot{animation:none;}
    .booking-card{animation:none; opacity:1; transform:none;}
    .card,.route-stop,.testimonial{opacity:1; transform:none; transition:none;}
  }
</style>
</head>
<body>

<!-- HERO -->
<section class="hero">
  <div class="container">
    <div class="hero-copy">
      <span class="eyebrow">Taxi Service · Pune</span>
      <h1>Every trip<br>runs on <span class="accent">time.</span></h1>
      <p class="lede">
        Eva Tours and Travels puts a clean, well-maintained cab on your route —
        airport drops, outstation trips, local sightseeing or a daily office
        commute. One call from Sushil Kale's team and a driver is on the way.
      </p>
      <div class="hero-actions">
        <a href="tel:+919284153392" class="btn btn-primary">Call &amp; Book a Cab</a>
        <a href="#services" class="btn btn-ghost">See Services</a>
      </div>
    </div>

    <div class="booking-card">
      <div class="booking-card__top">
        <div class="booking-card__label">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Booking Line
        </div>
        <span class="status-pill"><span class="dot"></span> Open 24×7</span>
      </div>

      <a href="tel:+919284153392" class="booking-card__number">92841 53392</a>
      <p class="booking-card__hint">Tap to call — a cab is usually assigned within minutes.</p>

      <div class="booking-card__footer">
        <div class="owner-row">
          <div class="owner-avatar">SK</div>
          <div class="owner-meta">
            <strong>Sushil Kale</strong>
            <span>Owner, Eva Tours &amp; Travels</span>
          </div>
        </div>
        <a href="tel:+919284153392" class="booking-card__cta">
          Call now
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- QUICK SERVICES -->
<section id="services">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">What We Drive</span>
      <h2>Taxi service for every kind of trip</h2>
      <p>No tour packages, no middlemen — just a cab, a driver, and a route you need covered.</p>
    </div>

    <div class="grid grid-4">
      <div class="card">
        <svg class="icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="6" y="18" width="36" height="14" rx="3" stroke="#2f6f52" stroke-width="2.5"/><path d="M10 18l3-8h22l3 8" stroke="#2f6f52" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="15" cy="34" r="3" fill="#f2a93b"/><circle cx="33" cy="34" r="3" fill="#f2a93b"/></svg>
        <h3>Local City Rides</h3>
        <p>Point-to-point cabs within Pune, metered and on time.</p>
      </div>
      <div class="card">
        <svg class="icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 24h36M30 12l12 12-12 12" stroke="#2f6f52" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <h3>Outstation Trips</h3>
        <p>One-way or round trips to any city, with an experienced highway driver.</p>
      </div>
      <div class="card">
        <svg class="icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M24 6c-7 0-12 5.5-12 12 0 9 12 24 12 24s12-15 12-24c0-6.5-5-12-12-12z" stroke="#2f6f52" stroke-width="2.5"/><circle cx="24" cy="18" r="4" fill="#f2a93b"/></svg>
        <h3>Airport Transfers</h3>
        <p>Flight-timed pickups and drops, tracked so you're never left waiting.</p>
      </div>
      <div class="card">
        <svg class="icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="24" cy="24" r="16" stroke="#2f6f52" stroke-width="2.5"/><path d="M24 15v9l6 4" stroke="#f2a93b" stroke-width="2.5" stroke-linecap="round"/></svg>
        <h3>Hourly Rentals</h3>
        <p>Car-on-call for meetings, errands or a full day out — pay by the hour.</p>
      </div>
    </div>
  </div>
</section>

<!-- HOW BOOKING WORKS -->
<section class="section-alt">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">The Route To Your Ride</span>
      <h2>Booking a cab, step by step</h2>
      <p>Four stops between your call and your ride showing up at the door.</p>
    </div>

    <div class="route">
      <div class="route-track" aria-hidden="true"></div>
      <ol class="route-stops">
        <li class="route-stop">
          <div class="stop-content">
            <h3>1 · Call or Message</h3>
            <p>Ring 9284153392 or 9284153393 with your pickup point and destination.</p>
          </div>
          <div class="pin">1</div>
          <div class="spacer"></div>
        </li>
        <li class="route-stop">
          <div class="spacer"></div>
          <div class="pin">2</div>
          <div class="stop-content">
            <h3>2 · Get a Fixed Fare</h3>
            <p>We confirm the cab type and quote a clear, upfront fare — no surprises later.</p>
          </div>
        </li>
        <li class="route-stop">
          <div class="stop-content">
            <h3>3 · Driver Arrives</h3>
            <p>A verified driver reaches your pickup point at the agreed time.</p>
          </div>
          <div class="pin">3</div>
          <div class="spacer"></div>
        </li>
        <li class="route-stop">
          <div class="spacer"></div>
          <div class="pin">4</div>
          <div class="stop-content">
            <h3>4 · Ride &amp; Pay</h3>
            <p>Sit back for the trip and pay by cash or UPI at the end — simple.</p>
          </div>
        </li>
      </ol>
    </div>
  </div>
</section>

<!-- STATS -->
<section class="section-ink">
  <div class="container">
    <div class="stats">
      <div class="stat"><strong>24×7</strong><span>Booking Line</span></div>
      <div class="stat"><strong>100+</strong><span>Routes Covered</span></div>
      <div class="stat"><strong>Fixed</strong><span>Upfront Fares</span></div>
      <div class="stat"><strong>Verified</strong><span>Local Drivers</span></div>
    </div>
  </div>
</section>

<!-- TESTIMONIALS -->
<section>
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">On The Record</span>
      <h2>What riders say</h2>
    </div>
    <div class="grid grid-3">
      <div class="testimonial">
        Booked an early morning airport cab and the driver was waiting five minutes before pickup. Clean car, easy payment.
        — Frequent Flyer, Pune
      </div>
      <div class="testimonial">
        Used Eva Tours for a Pune–Mahabaleshwar round trip. Fare was fixed upfront and the driver knew the ghat roads well.
        — Weekend Traveller
      </div>
      <div class="testimonial">
        Our office now books the hourly package for client visits. Reliable, and Sushil ji personally follows up.
        — Corporate Client
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section-alt">
  <div class="container">
    <div class="booking-card centered">
      <div class="booking-card__top">
        <span class="status-pill"><span class="dot"></span> Open 24×7</span>
      </div>
      <h2>Need a cab right now?</h2>
      <p class="booking-card__hint">Call Sushil Kale's team and a driver will be assigned in minutes.</p>
      <div class="dual-numbers">
        <a href="tel:+919284153392"><small>Primary</small><strong>9284153392</strong></a>
        <a href="tel:+919284153393"><small>Alternate</small><strong>9284153393</strong></a>
      </div>
    </div>
  </div>
</section>

<script>
  // Reveal cards, route steps and testimonials as they scroll into view
  (function () {
    var targets = document.querySelectorAll('.card, .route-stop, .testimonial');
    if (!('IntersectionObserver' in window) || !targets.length) {
      targets.forEach(function (el) { el.classList.add('in-view'); });
      return;
    }
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

    targets.forEach(function (el, i) {
      el.style.transitionDelay = (i % 4) * 60 + 'ms';
      observer.observe(el);
    });
  })();

  // Lightweight click tracking on every call link
  document.addEventListener('click', function (e) {
    var link = e.target.closest('a[href^="tel:"]');
    if (!link) return;
    console.log('Call link tapped:', link.getAttribute('href'));
  });
</script>

</body>
</html>

<%- include('partials/footer') %>